{
  "name": "chofyai-studio",
  "private": true,
  "version": "0.5.1",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev:web": "vite",
    "build:web": "vite build",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:app": "tauri build --bundles app",
    "tauri:build:dmg": "tauri build --bundles dmg",
    "tauri:build:mac": "tauri build --config src-tauri/tauri.macos.conf.json --bundles app,dmg",
    "package:mac": "bash scripts/mac/build-release.sh",
    "preflight:mac": "bash scripts/mac/preflight-build.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "cd src-tauri && cargo test"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "latest",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
